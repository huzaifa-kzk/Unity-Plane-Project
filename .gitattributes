# Set default behavior to automatically normalize line endings
* text=auto
# Treat Unity meta and shader files as text
*.cs text
*.shader text
*.shadergraph text
*.meta text
*.txt text
*.json text
*.xml text
*.asset text
*.controller text
# Binary files
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg binary
*.fbx binary
*.prefab binary
*.mat binary
*.mp4 binary
*.wav binary
*.ogg binary
*.tga binary
*.unity filter=lfs diff=lfs merge=lfs -text
Assets/TerrainTexturesPackFree/TerrainTextures/*.png filter=lfs diff=lfs merge=lfs -text
Assets/TerrainTexturesPackFree/DemoScene/*.unity filter=lfs diff=lfs merge=lfs -text
