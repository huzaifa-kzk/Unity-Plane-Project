
 BLOCK EVERYTHING outside current directory
../*

# Block Unity specifically (multiple patterns)
..\unity-plane\
..\unity-plane\*
*\unity*
unity-plane\

# Block all Unity file types
*.cs
*.unity
*.prefab
*.asset
*.controller
*.csproj
*.sln
*.mp4
*.mov
*.avi

# Block but allow React Native app
!package.json
!package-lock.json
!eas.json
!app.json
!App.*
!assets/
!src/
!components/
!*.js
!*.jsx
!*.ts
!*.tsx
