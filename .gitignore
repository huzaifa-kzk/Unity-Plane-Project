# Keep Unity source, scenes, prefabs, and metadata in git.
# Put private/licensed assets in this folder as a private git submodule,
# private repo checkout, or Git LFS-backed asset pack.
unity-plane/Assets/PrivateAssets/*
!unity-plane/Assets/PrivateAssets/.gitkeep

# Optional local note with private asset download/repo details.
unityassets.local

